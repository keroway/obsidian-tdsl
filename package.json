{
	"name": "obsidian-tdsl",
	"version": "1.0.0",
	"description": "Timeline DSL plugin for Obsidian — renders .tdsl code blocks as SVG",
	"main": "main.js",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "node esbuild.config.mjs production",
		"test": "vitest run",
		"test:coverage": "vitest run --coverage",
		"lint": "eslint src",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"typecheck": "tsc --noEmit",
		"version": "node version-bump.mjs && git add manifest.json versions.json"
	},
	"keywords": [
		"obsidian-plugin",
		"timeline",
		"dsl",
		"wasm",
		"svg"
	],
	"author": "keroway",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"@vitest/coverage-v8": "^4.1.10",
		"builtin-modules": "^5.3.0",
		"esbuild": "^0.28.1",
		"eslint": "^10.7.0",
		"obsidian": "1.13.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.9"
	},
	"dependencies": {
		"@keroway/tdsl-wasm": "^1.24.0"
	}
}
